  <indiceData>k__BackingField: {fileID: 11400000, guid: bce9b9a2ad141a6448984378653078fb, type: 2}
  lines:
  - speaker: Vilain
    sprite: {fileID: 0}
    text: "Un autre d\xE9tectus qui va subir un mauvais sort."
    typingSpeed: 0.05
  - speaker: Noir
    sprite: {fileID: 21300000, guid: 25979d6c84086b449b18fd3ed312690c, type: 3}
    text: "Qu\u2019est-ce que tu fais \xE0 la d\xE9tectus pr\xE9c\xE9dente !"
    typingSpeed: 0.05
  - speaker: Vilain
    sprite: {fileID: 0}
    text: "Moi, rien... \r\nJ\u2019ai plusieurs acolytes sous mon aile.\r\n"
    typingSpeed: 0.05
  - speaker: Vilain
    sprite: {fileID: 0}
    text: "Tu iras la voir \xE0 son travail. \r\n\r\n"
    typingSpeed: 0.05
  - speaker: Vilain
    sprite: {fileID: 0}
    text: Adieu sale mutant !
    typingSpeed: 0.05
